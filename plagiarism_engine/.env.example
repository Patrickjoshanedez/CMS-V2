# ─────────────────────────────────────────────────────────────────────────────
# Plagiarism Engine — Environment Variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# All variables have sane defaults in config.py.
# Only override what differs from those defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Celery / Redis ─────────────────────────────────────────────────────────────
# Default uses the plagiarism_redis container on port 6379 (internal Docker network).
# When running locally without Docker, change to your local Redis port.
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Path where ChromaDB persists the HNSW index on disk
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION_NAME=capstone_documents

# ── Embedding Model ───────────────────────────────────────────────────────────
# Model name — must be available on HuggingFace Hub or locally
# Options: all-MiniLM-L6-v2 (fast) | all-mpnet-base-v2 (higher quality)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Sentence batch size for encode_batch() — reduce to 8 if running on CPU with <8 GB RAM
EMBEDDING_BATCH_SIZE=32

# ── Winnowing ─────────────────────────────────────────────────────────────────
# k-gram character length
KGRAM_SIZE=50

# Sliding window size (number of k-grams per window)
WINDOW_SIZE=100

# Max gap between two adjacent matched spans before they are kept separate (chars)
WINNOW_MERGE_GAP=20

# Minimum span length to report as a match (chars) — filters noise
MIN_MATCH_SPAN=30

# ── Semantic Search ───────────────────────────────────────────────────────────
# Number of candidate documents retrieved from ChromaDB for deep winnowing
TOP_K_CANDIDATES=5

# Cosine similarity threshold — candidates below this are discarded before
# Winnowing (lower = more candidates examined, higher = faster but may miss paraphrases)
SEMANTIC_SIMILARITY_THRESHOLD=0.45

# ── Score Blending ─────────────────────────────────────────────────────────────
# Weights must sum to 1.0
PLAGIARISM_SCORE_WEIGHT_WINNOW=0.7
PLAGIARISM_SCORE_WEIGHT_SEMANTIC=0.3

# ── HNSW Index Parameters ────────────────────────────────────────────────────
# M          — number of bi-directional links per HNSW layer (higher = better recall, more memory)
# ef_construction — size of dynamic candidate list during index build (higher = better recall, slower build)
# ef_search  — size of dynamic candidate list during query (higher = better recall, slower query)
HNSW_SPACE=cosine
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=100

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001

# Comma-separated list of allowed CORS origins (for development use *)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Set to "true" to output structured JSON logs (recommended for production)
LOG_JSON=false
