# ============================================
# CMS V2 — Production Docker Environment
# ============================================
# Copy this file to .env.prod and set real values.
# NEVER commit .env.prod to version control.

# --- App ---
NODE_ENV=production
PORT=5000
CLIENT_URL=http://localhost:8080

# --- Database / Cache ---
MONGODB_URI=mongodb://mongodb:27017/cms_v2
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_redis_password
# URL-encoded version of REDIS_PASSWORD for Redis URLs used by Celery.
REDIS_PASSWORD_URLENC=change_me_strong_redis_password_url_encoded

# --- JWT (REQUIRED) ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- OTP ---
OTP_EXPIRES_MINUTES=10

# --- Email (optional, but recommended) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cms-buksu.edu.ph

# --- AWS S3 ---
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# --- Plagiarism / Captcha ---
RECAPTCHA_SECRET_KEY=

# --- Plagiarism Engine Compute Tuning ---
# Torch wheel variant in plagiarism image: cpu | cu121
PLAGIARISM_TORCH_VARIANT=cu121
# GPU request for Docker Compose. Use all for acceleration or set to none on CPU-only hosts.
PLAGIARISM_GPU_REQUEST=all
# Runtime device selection inside the engine: auto | cpu | cuda | cuda:0 | mps
PLAGIARISM_EMBEDDING_DEVICE=auto
PLAGIARISM_EMBEDDING_BATCH_SIZE=16
PLAGIARISM_WORKER_CONCURRENCY=2
PLAGIARISM_MAX_TASKS_PER_CHILD=100
PLAGIARISM_PREFETCH_MULTIPLIER=1
PLAGIARISM_API_WORKERS=1
PLAGIARISM_API_LIMIT_CONCURRENCY=32
PLAGIARISM_OMP_NUM_THREADS=2
PLAGIARISM_MKL_NUM_THREADS=2
PLAGIARISM_TORCH_NUM_THREADS=2

# --- Google OAuth / Drive ---
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CAPSTONE_DOCS_FOLDER_ID=
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=

# --- Vite public build vars (baked into the client bundle at build time) ---
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
VITE_GOOGLE_ALLOWED_ORIGINS=https://your-subdomain.ngrok-free.dev
VITE_RECAPTCHA_ENABLED=false
RECAPTCHA_ENABLED=false

# --- ngrok (required only when running ngrok service) ---
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
NGROK_BASIC_AUTH=
