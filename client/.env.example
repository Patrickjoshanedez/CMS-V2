# ============================================
# CMS V2 — Client Environment Variables (Vite)
# ============================================
# Copy this file to .env and fill in the values.
# All Vite env vars must be prefixed with VITE_
# NEVER commit .env to version control.
# ============================================

# API base URL (optional — defaults to /api which is proxied by Vite dev server).
# In production, set to your deployed API domain:
#   VITE_API_URL=https://api.cms-buksu.edu.ph/api
VITE_API_URL=

# Dev proxy target used by Vite for /api and /socket.io.
# Defaults to http://127.0.0.1:5001 in vite.config.js.
# Override this when your backend runs on another host/port (for example LAN or Docker).
# VITE_API_PROXY_TARGET=http://127.0.0.1:5001

# Google OAuth2 client ID (from Google Cloud Console > Credentials > OAuth 2.0 Client ID)
# Required for the "Sign in with Google" button.
# Must be the same client ID expected by the server GOOGLE_CLIENT_ID.
# Also ensure your active frontend URL origin is added to
# Google Cloud Console -> Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=your_google_oauth2_client_id_here

# Optional: limit which frontend origins should render Google Sign-In in this app.
# Comma-separated list. If current origin is not in this list, Google Sign-In is hidden.
# Useful when your Google OAuth client does not allow localhost yet.
# VITE_GOOGLE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: in development, Google Sign-In is disabled by default to avoid
# origin-mismatch noise unless you explicitly enable it.
# Set to true only after adding your local origin in Google Cloud Console.
# VITE_ENABLE_GOOGLE_LOGIN=true

# --- reCAPTCHA ---
# Set to false for faster local testing (widget hidden and token not required)
VITE_RECAPTCHA_ENABLED=true
VITE_RECAPTCHA_SITE_KEY=
