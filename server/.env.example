# ============================================
# CMS V2 — Server Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- JWT ---
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- OTP ---
OTP_EXPIRES_MINUTES=10

# --- Email (SMTP) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here
EMAIL_FROM="CMS V2 <noreply@cms-buksu.edu.ph>"

# --- Client URL (for CORS) ---
CLIENT_URL=http://localhost:5173

# --- AWS S3 (Cloud Storage) ---
# For local dev, use LocalStack: http://localhost:4566
# For production, remove S3_ENDPOINT or leave blank to use real AWS
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=cms-buksu-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true

# --- Upload Limits ---
MAX_UPLOAD_SIZE_MB=25

# --- Redis (for BullMQ — Phase 2) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- Plagiarism Engine ---
PLAGIARISM_ENGINE_URL=http://localhost:8001
PLAGIARISM_ENGINE_TIMEOUT=120000

# --- reCAPTCHA ---
# Set to false for faster local testing (captcha middleware bypassed)
RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=

# Plagiarism Thresholds (0-100)
PLAGIARISM_WARNING_THRESHOLD=30
PLAGIARISM_REJECT_THRESHOLD=50

# Polling Configuration
PLAGIARISM_POLL_INTERVAL=2000
PLAGIARISM_POLL_MAX_ATTEMPTS=60

# Data Retention (90 days in seconds)
PLAGIARISM_RESULTS_TTL=7776000

# --- Google Docs / Drive (Editable drafts + Drive retrieval) ---
# Service account credentials (required for Google integration)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINE_1\nYOUR_KEY_LINE_2\n-----END PRIVATE KEY-----\n"

# Root fallback folder for Google Drive uploads
GOOGLE_DRIVE_FOLDER_ID=

# Single folder containing the full-paper template Google Doc(s)
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=

# Institutional archive folder for mirrored final capstone docs
GOOGLE_DRIVE_CAPSTONE_DOCS_FOLDER_ID=
