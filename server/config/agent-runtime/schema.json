{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CMS Agent Runtime Configuration",
  "type": "object",
  "required": [
    "id",
    "version",
    "status",
    "modeProfiles",
    "confidencePolicy",
    "verification",
    "triggerPolicies"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated"] },
    "activatedAt": { "type": "string", "format": "date-time" },
    "checksum": { "type": "string" },
    "modeProfiles": {
      "type": "object",
      "required": ["execution", "explainability", "proactive"],
      "properties": {
        "execution": { "$ref": "#/$defs/modeProfile" },
        "explainability": { "$ref": "#/$defs/modeProfile" },
        "proactive": { "$ref": "#/$defs/modeProfile" }
      }
    },
    "confidencePolicy": {
      "type": "object",
      "required": ["high", "medium", "low"],
      "properties": {
        "high": { "$ref": "#/$defs/confidenceBand" },
        "medium": { "$ref": "#/$defs/confidenceBand" },
        "low": { "$ref": "#/$defs/confidenceBand" }
      }
    },
    "verification": {
      "type": "object",
      "required": ["autoTrigger", "steps"],
      "properties": {
        "autoTrigger": {
          "type": "array",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "triggerPolicies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "when", "action", "decisionMode"],
        "properties": {
          "name": { "type": "string" },
          "when": { "type": "array", "items": { "type": "string" } },
          "action": { "type": "array", "items": { "type": "string" } },
          "decisionMode": { "type": "string", "enum": ["BLOCK", "WARN", "LOG"] }
        }
      }
    },
    "browserVerification": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "requiredScenarios": { "type": "array", "items": { "type": "string" } }
      }
    },
    "pluginRegistry": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "enabled", "triggers"],
        "properties": {
          "id": { "type": "string" },
          "enabled": { "type": "boolean" },
          "triggers": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "$defs": {
    "modeProfile": {
      "type": "object",
      "required": ["useWhen", "behaviors"],
      "properties": {
        "useWhen": { "type": "array", "items": { "type": "string" } },
        "behaviors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "confidenceBand": {
      "type": "object",
      "required": ["min", "max", "policy"],
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "policy": { "type": "string" }
      }
    }
  }
}
