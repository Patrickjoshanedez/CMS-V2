# Google Docs Integration Template
# 
# Add these variables to your .env file for full Google Docs integration
# See docs/GOOGLE_DOCS_INTEGRATION.md for setup instructions

# ============================================================================
# GOOGLE DRIVE SERVICE ACCOUNT (Required for Google Docs)
# ============================================================================

# Service account email from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service account private key (multiline JSON key)
# Format: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# ============================================================================
# GOOGLE DRIVE FOLDER CONFIGURATION
# ============================================================================

# Root Google Drive folder ID (where all capstone docs are stored)
GOOGLE_DRIVE_FOLDER_ID=your-root-folder-id

# Capstone docs folder ID (institutional archive location)
GOOGLE_DRIVE_CAPSTONE_DOCS_FOLDER_ID=your-capstone-docs-folder-id

# Template folder ID (where cloned documents are stored)
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=your-template-folder-id

# ============================================================================
# GOOGLE DOCS TEMPLATE (NEW - Enables Google Docs integration)
# ============================================================================

# Master template Google Doc ID for cloning
# This is the document that will be cloned each time a student submits
# Get the ID from the URL: https://docs.google.com/document/d/{DOCUMENT_ID}/edit
# 
# IMPORTANT: 
# 1. Grant the service account Editor access to this document
# 2. Place the template in GOOGLE_DRIVE_TEMPLATE_FOLDER_ID
# 3. Ensure the template has professional formatting and placeholder text
GOOGLE_DRIVE_TEMPLATE_FULL_PAPER_ID=your-master-template-doc-id

# ============================================================================
# INSTRUCTIONS FOR SETUP
# ============================================================================

# Step 1: Create a Master Template
#   - Go to Google Drive
#   - Create a new Google Doc with your standard formatting
#   - Copy the doc ID from the URL
#   - Add that ID to GOOGLE_DRIVE_TEMPLATE_FULL_PAPER_ID

# Step 2: Set Up Service Account Access
#   - Open the template doc → Share
#   - Add your service account email
#   - Grant Editor role
#   - Repeat for all folders referenced above

# Step 3: Get Your Service Account Credentials
#   - Go to Google Cloud Console
#   - Select your project
#   - Go to Service Accounts
#   - Select your service account
#   - Keys tab → Add Key → JSON
#   - Download JSON and extract:
#       - client_email → GOOGLE_SERVICE_ACCOUNT_EMAIL
#       - private_key → GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY

# Step 4: Get Your Folder IDs
#   - Open Drive folders in browser
#   - Copy folder ID from URL: https://drive.google.com/drive/folders/{FOLDER_ID}

# ============================================================================
# VERIFICATION
# ============================================================================

# To verify configuration is correct, run:
#   npm run test -- google-docs.integration.test.js
#
# The test will:
#   1. Clone the template document
#   2. Set "Anyone Can Edit" permission
#   3. Return an edit link
#   4. Log all operations to audit trail
