{
  "version": "1.2.0",
  "schemaVersion": 1,
  "description": "Workspace hook registry for orchestrator lifecycle enforcement.",
  "hooks": {
    "PreToolUse": {
      "enabled": true,
      "handlers": [
        {
          "id": "public-internet-exposure-gate",
          "script": ".github/hooks/scripts/continual_learning_checkpoint.py",
          "timeoutMs": 15000,
          "failMode": "error"
        }
      ]
    },
    "PostToolUse": {
      "enabled": true,
      "handlers": [
        {
          "id": "continual-learning-checkpoint",
          "script": ".github/hooks/scripts/continual_learning_checkpoint.py",
          "timeoutMs": 15000,
          "failMode": "error"
        }
      ]
    },
    "PostTaskCompletion": {
      "enabled": true,
      "handlers": [
        {
          "id": "continual-learning-checkpoint",
          "script": ".github/hooks/scripts/continual_learning_checkpoint.py",
          "timeoutMs": 15000,
          "failMode": "error"
        }
      ]
    }
  }
}
